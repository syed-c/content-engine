# ContentEngine - Environment Variables
# Copy this to .env.local and fill in your values

# ===================
# SUPABASE (Required)
# ===================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===================
# AI - Groq (Required)
# ===================
GROQ_API_KEY=your-groq-api-key

# ===================
# SEO Data (Required)
# ===================
DATAFORSEO_USER=your-dataforseo-username
DATAFORSEO_PASSWORD=your-dataforseo-password
# Base64 encoded "user:password" - generate at: https://app.dataforseo.com/api-client/password
DATAFORSEO_BASE64=your-base64-encoded-credentials

# ===================
# UNSPLASH (Optional)
# ===================
# For auto-featured images - get at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ===================
# EMAIL - Resend (Optional)
# ===================
# For team invites, rank alerts, batch notifications
RESEND_API_KEY=your-resend-api-key

# ===================
# CRON (Optional)
# ===================
# Secret for scheduled publish cron job
CRON_SECRET=your-random-secret-string

# ===================
# STRIPE (Optional)
# ===================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
